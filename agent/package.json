{
  "name": "mamcr-agent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:server": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build && npm run build:server",
    "start": "node --env-file=.env dist/index.js",
    "serve": "npm run build:all && node dist-electron/main.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:serve": "tsx electron/main.ts",
    "load-db": "tsx --env-file=.env src/db/loader.ts",
    "extract": "tsx --env-file=.env src/extract.ts",
    "embed": "tsx --env-file=.env src/db/embed.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "file:../../pi-mono/packages/ai",
    "@mariozechner/pi-coding-agent": "file:../../pi-mono/packages/coding-agent",
    "@sinclair/typebox": "^0.34.41",
    "better-sqlite3": "^11.0.0",
    "csv-parse": "^5.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
